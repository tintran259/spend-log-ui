{
  "expo": {
    "name": "Spend Log",
    "slug": "spendlog",
    "owner": "tintran",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "spendlog",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spendlog.app",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.38422875346-ssfdpan6tpj2nsgv0ork8vvl6iuik7r7"
            ]
          }
        ],
        "LSApplicationQueriesSchemes": [
          "fbapi",
          "fb-messenger-share-api",
          "fbauth2",
          "fbshareextension"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#7C3AED"
      },
      "package": "com.spendlog.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-camera",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Spend Log dùng vị trí của bạn để hiển thị thời tiết địa phương."
        }
      ],
      "expo-web-browser",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}